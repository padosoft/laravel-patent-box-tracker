  "plugins": {
    "search": {
      "semantic": true,
      "model": "Xenova/all-MiniLM-L6-v2",
      "chunkSize": 512,
      "chunkOverlap": 64,
      "topK": 10,
      "showConfidence": true
    },
    "git": {
      "repo": "https://github.com/padosoft/laravel-patent-box-tracker",
      "branch": "main",
      "lastUpdated": true,
      "commitHistory": true,
      "maxCommits": 5
    },
    "seo": {
      "author": "Lorenzo Padovani",
      "twitter": "@padosoft"
    },
    "sitemap": {
      "defaultChangefreq": "weekly",
      "defaultPriority": 0.8,
      "rootPriority": 1
    },
    "mermaid": {},
    "math": {},
    "llms": {},
    "analytics": false
  }
