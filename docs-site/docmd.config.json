          "title": "ADR",
          "path": "/architettura/adr"
        }
      ]
    },
    {
      "title": "Best Practices",
      "items": [
        {
          "title": "Classification Hygiene",
          "path": "/best-practices/classification-hygiene"
        },
        {
          "title": "Evidence Strategy",
          "path": "/best-practices/evidence-strategy"
        }
