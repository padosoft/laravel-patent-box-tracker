          "path": "/guides/single-repository"
        },
        {
          "title": "Cross Repository Runs",
          "path": "/guides/cross-repository"
        },
        {
          "title": "Worked Example",
          "path": "/guides/worked-example"
        }
      ]
    },
    {
      "title": "Concetti & Teoria",
      "items": [
        {
          "title": "Motivazione",
          "path": "/concetti/motivazione"
        },
        {
          "title": "Teoria",
          "path": "/concetti/teoria"
        },
        {
          "title": "Gotcha & Limits",
          "path": "/concetti/gotcha-limits"
