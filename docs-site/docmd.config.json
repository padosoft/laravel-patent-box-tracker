{
  "title": "laravel-patent-box-tracker",
  "description": "Audit-grade Italian Patent Box dossier generator for Laravel.",
  "url": "https://doc.laravel-patent-box-tracker.padosoft.com",
  "src": "docs-site/content",
  "out": "_site",
  "base": "/",
  "favicon": "docs-site/assets/favicon.svg",
  "copyCode": true,
  "pageNavigation": true,
  "minify": true,
  "theme": {
    "name": "default",
    "appearance": "system",
    "primaryColor": "#0d9488",
    "customCss": [
      "docs-site/assets/custom.css"
    ]
  },
  "layout": {
    "spa": true,
    "header": {
      "enabled": true
    },
    "sidebar": {
      "enabled": true,
      "collapsible": true,
      "defaultCollapsed": false
    },
    "footer": {
      "style": "minimal",
      "content": "Apache-2.0. Built by Padosoft for audit-grade Patent Box documentation."
    },
    "menubar": {
      "enabled": true,
      "left": [
        {
          "text": "Docs",
          "url": "/"
        },
        {
          "text": "GitHub",
          "url": "https://github.com/padosoft/laravel-patent-box-tracker"
        },
        {
          "text": "Packagist",
          "url": "https://packagist.org/packages/padosoft/laravel-patent-box-tracker"
        }
      ]
    },
    "optionsMenu": {
      "position": "header",
      "components": {
        "search": true,
        "themeSwitch": true,
        "sponsor": null
      }
    }
  },
  "navigation": [
    {
      "title": "Get Started",
      "items": [
        {
          "title": "Overview",
          "path": "/"
        },
        {
          "title": "Quickstart",
